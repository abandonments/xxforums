
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // helper for staff
    function isStaff() {
       return request.auth != null && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Root'];
    }
    
    function isRoot() {
       return request.auth != null && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Root';
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isStaff());
    }
    
    match /threads/{threadId} {
      allow read: if true;
      allow create: if request.auth != null;
      // check author (uid) OR authorId (legacy uid) OR staff
      allow update, delete: if request.auth != null && (
        resource.data.author == request.auth.uid || 
        resource.data.authorId == request.auth.uid || 
        isStaff()
      );
    }
    
    match /replies/{replyId} {
      allow read: if true;
      allow create: if request.auth != null;
      // check author (uid) OR authorId (legacy uid) OR staff
      allow update, delete: if request.auth != null && (
        resource.data.author == request.auth.uid || 
        resource.data.authorId == request.auth.uid || 
        isStaff()
      );
    }

    // generic stuff
    match /notifications/{n} { allow read, write: if request.auth != null; }
    match /messages/{m} { allow read, write: if request.auth != null; }
    match /profileComments/{c} { allow read, write: if request.auth != null; }
    match /counters/{c} { allow read, write: if request.auth != null; }
    
    // Payment rules - Only Root can read all, User can read their own (simplified to auth for now to support create)
    match /payments/{p} { allow read, write: if request.auth != null; }
    match /escrows/{e} { allow read, write: if request.auth != null; }
    match /escrows/{e}/messages/{m} { allow read, write: if request.auth != null; }
  }
}
