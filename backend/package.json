{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch './**/*.ts' --exec 'node --no-warnings --import ts-node/esm ./index.ts'",
    "test": "tsc && mocha --exit --timeout 10000 --file dist/test/testSetup.js dist/test/**/*.test.js",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts --fix",
    "format": "prettier --write \"./**/*.{js,ts,json,css,md}\"",
    "format:check": "prettier --check \"./**/*.{js,ts,json,css,md}\"",
    "audit": "npm audit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.6.1",
    "form-data": "^4.0.5",
    "knex": "^3.1.0",
    "monero-ts": "^0.11.8",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "pg": "^8.18.0",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-validator": "^2.20.33",
    "@types/knex": "^0.15.2",
    "@types/mocha": "^10.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/node-cache": "^4.1.3",
    "@types/pg": "^8.16.0",
    "@types/sinon": "^21.0.0",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.3",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "chai": "^6.2.2",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
